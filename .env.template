PORT=3000
NODE_ENV=development

# JWT (debe ser IDÉNTICO al de api-usuarios)
JWT_SECRET=cambiar_esta_clave_en_produccion

# Secreto interno: autentica al gateway ante los microservicios (debe ser IDÉNTICO en los 4).
# Sin él, cualquiera podría pegarle directo a la URL pública de un microservicio.
INTERNAL_SECRET=secreto_largo_para_seguridad_en_microservicios

# URLs de los microservicios
# Local: http://localhost:300X   |   Prod: URLs públicas de cada servicio en Render
USUARIOS_URL=http://localhost:3001
CANCHAS_URL=http://localhost:3002
TURNOS_URL=http://localhost:3003
PAGOS_URL=http://localhost:3004
